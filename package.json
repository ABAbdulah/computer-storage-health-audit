{
  "name": "spacescope",
  "version": "1.0.1",
  "description": "SpaceScope — a beautiful desktop disk space analyzer. See exactly where every gigabyte went.",
  "author": "SpaceScope Contributors",
  "license": "MIT",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "build": "electron-vite build && electron-builder --config electron-builder.config.cjs",
    "build:dir": "electron-vite build && electron-builder --dir --config electron-builder.config.cjs",
    "release": "electron-vite build && electron-builder --config electron-builder.config.cjs --publish always"
  },
  "dependencies": {
    "d3-hierarchy": "^3.1.2"
  },
  "devDependencies": {
    "@types/d3-hierarchy": "^3.1.7",
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "electron": "^31.2.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "framer-motion": "^11.3.2",
    "lucide-react": "^0.408.0",
    "postcss": "^8.4.39",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.12.7",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.5.3",
    "vite": "^5.3.3",
    "zustand": "^4.5.4"
  }
}
